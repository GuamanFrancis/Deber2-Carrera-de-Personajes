<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controlador.CarreraController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Carrera de Personajes">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <VBox spacing="10.0">
        <Label text="Perro" />
        <AnchorPane prefHeight="50.0" prefWidth="450.0" style="-fx-border-color: gray; -fx-background-color: #f0f0f0;">
            <ImageView fx:id="imgP1" fitHeight="40.0" fitWidth="40.0" layoutX="0.0" layoutY="5.0" pickOnBounds="true" preserveRatio="true" />
        </AnchorPane>
        
        <Label text="Hongo" />
        <AnchorPane prefHeight="50.0" prefWidth="450.0" style="-fx-border-color: gray; -fx-background-color: #f0f0f0;">
            <ImageView fx:id="imgP2" fitHeight="40.0" fitWidth="40.0" layoutX="0.0" layoutY="5.0" pickOnBounds="true" preserveRatio="true" />
        </AnchorPane>
        
        <Label text="Persona" />
        <AnchorPane prefHeight="50.0" prefWidth="450.0" style="-fx-border-color: gray; -fx-background-color: #f0f0f0;">
            <ImageView fx:id="imgP3" fitHeight="40.0" fitWidth="40.0" layoutX="0.0" layoutY="5.0" pickOnBounds="true" preserveRatio="true" />
        </AnchorPane>
    </VBox>

    <Label fx:id="lblGanador" textFill="RED">
        <font>
            <Font size="18.0" />
        </font>
    </Label>

    <VBox alignment="CENTER" spacing="10.0">
        <Button fx:id="btnIniciar" onAction="#iniciarCarrera" prefWidth="150.0" text="Iniciar Carrera" />
        <Button fx:id="btnReiniciar" onAction="#reiniciarCarrera" prefWidth="150.0" text="Reiniciar" />
    </VBox>
</VBox>
